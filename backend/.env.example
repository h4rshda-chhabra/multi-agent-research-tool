# Application
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./research.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/research

# AI APIs
GEMINI_API_KEY=AIza...
TAVILY_API_KEY=tvly-...

# CORS
# Development default — localhost is always included automatically.
FRONTEND_URL=http://localhost:3001
# Production (set on Render / your PaaS dashboard):
#   FRONTEND_URL=https://multi-agent-research-tool-ohbcniz8.vercel.app
#   CORS_ORIGINS=https://multi-agent-research-tool-ohbcniz8.vercel.app
# CORS_ORIGINS accepts a comma-separated list for preview deployments / custom domains.
CORS_ORIGINS=

# (Optional) Redis for production SSE queue
# REDIS_URL=redis://localhost:6379/0
